{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": ["<node_internals>/**"],
            "program": "${workspaceFolder}/build/main.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program - API",
            "skipFiles": ["<node_internals>/**"],
            "runtimeArgs": ["run", "api"],
            "runtimeExecutable": "pnpm",
            "outputCapture": "std", // enables pino logging to appear in console
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program - Bot",
            "skipFiles": ["<node_internals>/**"],
            "runtimeArgs": ["run", "bot"],
            "runtimeExecutable": "pnpm",
            "outputCapture": "std", // enables pino logging to appear in console
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program - Dev",
            "skipFiles": ["<node_internals>/**"],
            "runtimeArgs": ["run", "dev"],
            "runtimeExecutable": "pnpm",
            "outputCapture": "std", // enables pino logging to appear in console
            "env": {
                "NODE_ENV": "development"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program - Web",
            "skipFiles": ["<node_internals>/**"],
            "runtimeArgs": ["run", "web:dev"],
            "runtimeExecutable": "pnpm",
            "outputCapture": "std", // enables pino logging to appear in console
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program - Testing",
            "skipFiles": ["<node_internals>/**"],
            "runtimeArgs": ["run", "test"],
            "runtimeExecutable": "pnpm",
            "outputCapture": "std", // enables pino logging to appear in console
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
