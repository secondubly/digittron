{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compose Up",
			"type": "docker-compose",
			"dockerCompose": {
				"up": {
					"detached": true,
					"build": true
				},
				"envFile": "${workspaceFolder}/src/.env",
				"files": ["${workspaceFolder}/docker-compose.yml"]
			}
		},
		{
			"label": "Compose Up (Dev)",
			"type": "docker-compose",
			"dockerCompose": {
				"up": {
					"detached": false,
					"build": true,
					"profiles": ["dev"]
				},
				"envFile": "${workspaceFolder}/src/.env",
				"files": ["${workspaceFolder}/docker-compose.yml"]
			}
		},
		{
			"label": "Compose Down",
			"type": "docker-compose",
			"dockerCompose": {
				"down": {
					"removeVolumes": true,
					"removeImages": "all"
				}
			}
		}
	]
}
