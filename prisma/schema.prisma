// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  id                  Int               @id @default(autoincrement())
  name                String            @db.VarChar(255)
  oauth               String            @db.VarChar(255)
  refresh_token       String            @db.VarChar(255)
  value               Json?             @default("null")  @db.Json

  @@unique([id, name], name: "settings_id_name_unique")
  @@map("settings")
}

model Command {
  id                Int                 @default(autoincrement())
  name              String              @id @db.VarChar(255)
  aliases           Json?               @default("[]") @db.Json
  response          String
  enabled           Boolean             @default(true)
  visible           Boolean             @default(true)
  commandPermission CommandPermission?  @relation(fields: [name], references: [name], onDelete: Cascade) 

  @@map("commands")

}

model CommandPermission {
  name              String            @id @db.VarChar(255)
  level             PermissionLevel   @default(VIEWER)
  command           Command?

  @@map("command_permissions")
}

enum PermissionLevel {
  VIEWER
  FOLLOWER
  REGULAR
  VIP
  SUBSCRIBER
  MODERATOR
  EDITOR
  BROADCASTER
}