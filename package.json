    "lint": "eslint . --ext .ts",
    "mikro-orm": "mikro-orm",
    "seed": "mikro-orm-esm seeder:run",
    "test": "node --import tsx --test \"./tests/**/*.test.ts\"",
    "start": "node build/main.js",
    "web": "vite"
