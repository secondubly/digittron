{
  "name": "digittron",
  "version": "1.0.0",
  "description": "secondubly's twitch bot",
  "main": "dist/bot.js",
  "type": "module",
  "scripts": {
    "build": "tsc -b src",
    "format": "prettier --config src/.prettierrc 'src/**/*.ts' --write",
    "lint": "eslint --ignore-path \"src/.eslintignore\" -c \"src/.eslintrc\" --ext .js,.ts .",
    "start": "node dist/bot.js",
    "start:watch": "npx nodemon src/bot.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/secondubly/digittron.git"
  },
  "author": "secondubly",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/secondubly/digittron/issues"
  },
  "homepage": "https://github.com/secondubly/digittron#readme",
  "dependencies": {
    "@types/tmi.js": "^1.8.5",
    "dotenv": "^16.3.1",
    "dotenv-flow": "^4.0.0",
    "redis": "^4.6.10",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
